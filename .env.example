# ── DATABASE ────────────────────────────────────────────────────────────────────
# Connection string PostgreSQL dari Supabase (wajib)
# Ambil dari: Supabase → Settings → Database → URI
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── SESSION ─────────────────────────────────────────────────────────────────────
# String acak panjang untuk enkripsi session (wajib)
# Bisa generate di: https://generate-secret.vercel.app/64
SESSION_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter

# ── AI (opsional) ───────────────────────────────────────────────────────────────
# Diperlukan untuk fitur AI Report & AI Chat
# Ambil dari: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── SUPABASE STORAGE (opsional) ─────────────────────────────────────────────────
# Diperlukan untuk upload foto profil & file di production
# Ambil dari: Supabase → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── ADMIN ACCOUNT (opsional) ────────────────────────────────────────────────────
# Kalau tidak di-set, default: admin / Admin@AINA2024 / admin@aina.id
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@AINA2024
ADMIN_EMAIL=admin@aina.id
